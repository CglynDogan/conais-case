# ── Server ────────────────────────────────────────────────────────────────────
# Port for HTTP and WebSocket. Defaults to 3001 if not set.
PORT=3001

# ── Gemini LLM (optional) ─────────────────────────────────────────────────────
# Powers the batched coaching analysis (feedback, suggested questions, info card).
# If absent, the backend runs in rule-only mode — heuristics still fire, LLM path
# is silently skipped. The app works without this key.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Deepgram STT (required for browser-call mode) ─────────────────────────────
# Used to transcribe tab/system audio captured in browser-call mode.
# Also used by the legacy Twilio path if that is active.
# Without this key, browser-call mode connects but produces no transcripts.
# Model defaults to nova-3. Use nova-2-general as fallback if nova-3 is unavailable.
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-3

# ── Twilio MediaStream (legacy — not needed for browser-call mode) ─────────────
# Only required if routing calls via Twilio's MediaStream WebSocket.
# The recommended flow uses browser tab audio capture instead (no Twilio dependency).
# TWILIO_STREAM_URL=wss://your-ngrok-subdomain.ngrok.io/twilio-stream
# TWILIO_CALL_LANG=tr-TR
