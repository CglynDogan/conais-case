# ── Server ────────────────────────────────────────────────────────────────────
# Port for HTTP and WebSocket. Defaults to 3001 if not set.
PORT=3001

# ── LLM provider ──────────────────────────────────────────────────────────────
# Select which LLM powers the batched coaching layer.
# Options: gemini (default) | openai
# If the selected provider has no API key, the backend runs in rule-only mode.
LLM_PROVIDER=gemini

# ── Gemini (used when LLM_PROVIDER=gemini) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash   # optional — defaults to gemini-2.5-flash

# ── OpenAI (used when LLM_PROVIDER=openai) ────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5-mini         # optional — defaults to gpt-5-mini
# swap to gpt-5-nano for the second test

# ── Deepgram STT (required for browser-call mode) ─────────────────────────────
# Used to transcribe tab/system audio captured in browser-call mode.
# Without this key, browser-call mode connects but produces no transcripts.
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-3

# ── Twilio MediaStream (legacy — not needed for browser-call mode) ─────────────
# TWILIO_STREAM_URL=wss://your-ngrok-subdomain.ngrok.io/twilio-stream
# TWILIO_CALL_LANG=tr-TR
