# ── Server ────────────────────────────────────────────────────────────────────
# Port for HTTP and WebSocket. Defaults to 3001 if not set.
PORT=3001

# ── LLM provider ──────────────────────────────────────────────────────────────
# Select which LLM powers the batched coaching layer.
# Options: gemini (default) | openai
# If the selected provider has no API key, the backend runs in rule-only mode.
LLM_PROVIDER=gemini

# ── Gemini (used when LLM_PROVIDER=gemini) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── OpenAI (optional experiment — not recommended for demo) ───────────────────
# gpt-5-nano is unreliable for structured JSON output under real-time latency.
# Gemini (above) is the recommended default for this prototype.
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5-nano         # optional — defaults to gpt-5-nano

# ── Deepgram STT (required for browser-call mode) ─────────────────────────────
# Used to transcribe tab/system audio captured in browser-call mode.
# Without this key, browser-call mode connects but produces no transcripts.
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-3

